{
  "info": {
    "name": "User Service API Tests",
    "description": "Postman collection for exercising the user-service endpoints in the Home Services Marketplace app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "customerId",
      "value": "1"
    },
    {
      "key": "providerId",
      "value": "2"
    },
    {
      "key": "customerUsername",
      "value": "alice"
    },
    {
      "key": "providerUsername",
      "value": "bob_plumber"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Registration",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/customers/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "customers",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"password123\",\n  \"email\": \"alice@example.com\",\n  \"initialBalance\": 200.00\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Customer registration succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.userId) {",
                  "  pm.collectionVariables.set('customerId', json.userId);",
                  "}",
                  "if (json.username) {",
                  "  pm.collectionVariables.set('customerUsername', json.username);",
                  "}",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Provider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/providers/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "providers",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bob_plumber\",\n  \"password\": \"password123\",\n  \"email\": \"bob@example.com\",\n  \"professionType\": \"Plumber\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Provider registration succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.userId) {",
                  "  pm.collectionVariables.set('providerId', json.userId);",
                  "}",
                  "if (json.username) {",
                  "  pm.collectionVariables.set('providerUsername', json.username);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('authToken', json.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Add Funds",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
