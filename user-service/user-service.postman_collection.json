                "{{customerId}}",
                "wallet",
                "add"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Funds added', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Wallet Balance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}/wallet",
